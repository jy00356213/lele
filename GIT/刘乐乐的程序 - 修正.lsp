(defun c:DC ()
  (if (not JLB)
    (princ "
没有记录，请先运行 XX 标注。")
    (progn
      (setq fname (getfiled "导出 CSV" "" "csv" 1))
      (if fname
        (progn
          (setq f (open fname "w"))
          (write-line "编号,管径,管内底,管外顶,管外底" f)
          (foreach row (reverse JLB)
            (write-line
              (strcat (nth 0 row) "," (nth 1 row) "," (nth 2 row) "," (nth 3 row) "," (nth 4 row))
              f
            )
          )
          (close f)
          (princ (strcat "
已导出到: " fname))
          (command "_.start" fname)
        )
      )
    )
  )
  (princ)
)

