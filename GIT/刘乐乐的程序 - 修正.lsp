(defun show-jlb ()
  (if (not JLB)
    (princ "
没有记录，请先运行 XX 标注。")
    (progn
      (textscr)
      (princ "
==========================================")
      (princ "
 编号 | 管径       | 管内底  | 管外顶  | 管外底")
      (princ "
------------------------------------------")
      (foreach row (reverse JLB)
        (princ (strcat "
  " (nth 0 row) "  | " (nth 1 row) "  | " (nth 2 row) "  | " (nth 3 row) "  | " (nth 4 row)))
      )
      (princ "
==========================================")
      (princ (strcat "
共 " (itoa (length JLB)) " 条记录"))
    )
  )
  (princ)
)

(defun c:BBB ()
  (show-jlb)
